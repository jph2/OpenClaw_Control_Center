#!/usr/bin/env bash
# cm-release-telegram-session — release a Telegram group from a stale
# session-level auth profile override so the next inbound message
# re-binds via `bindings[]` to the CM-configured synth agent.
#
# Why this exists:
#   Once the OpenClaw gateway has an entry in
#     ~/.openclaw/agents/main/sessions/sessions.json
#   for `agent:main:telegram:group:<id>`, that entry can pin the session
#   to a specific `authProfileOverride` (e.g. openai-codex:you@...).
#   Session lookup short-circuits binding lookup, so any CM `bindings[]`
#   entry written *after* that session existed is ignored for this group.
#   Symptom: CM UI shows openai/gpt-4o, Telegram replies (when any) come
#   back on Codex/Kimi instead, or nothing comes back at all.
#
#   Synth agents under ~/.openclaw/agents/tars-*/sessions/sessions.json can
#   pin authProfileOverride too (e.g. moonshot:default → Kimi + literal
#   NO_REPLY). That is NOT this script's file — use instead:
#     node scripts/cm-unpin-synth-session-auth.mjs <groupId> [--dry-run]
#
# What this does (safe by default):
#   1. Finds the session entry keyed `agent:main:telegram:group:<groupId>`
#      in `~/.openclaw/agents/main/sessions/sessions.json`.
#   2. Snapshots the whole sessions.json file with a timestamped suffix
#      (kept next to the original — easy to restore or `trash` later).
#   3. Removes just that one entry from sessions.json (atomic rename).
#      The JSONL transcript file stays untouched on disk.
#   4. Optionally restarts openclaw-gateway.service so the in-memory
#      session cache is dropped.
#
# Usage:
#   cm-release-telegram-session <groupId> [--restart] [--dry-run]
#   cm-release-telegram-session --list
#
# Examples:
#   cm-release-telegram-session -5168034995 --dry-run
#   cm-release-telegram-session -5168034995 --restart
#   cm-release-telegram-session --list
#
# Exit code: 0 on success, 1 on any error, 2 if no matching entry found
# (already clean — that's not a failure; just reported).

set -euo pipefail

SESSIONS_FILE="${CM_MAIN_SESSIONS_FILE:-${HOME}/.openclaw/agents/main/sessions/sessions.json}"
GATEWAY_UNIT="${CM_GATEWAY_UNIT:-openclaw-gateway.service}"

group_id=""
restart=0
dry_run=0
list_only=0

usage() {
    sed -n '2,30p' "$0" | sed 's/^# \{0,1\}//'
    exit 1
}

[[ $# -eq 0 ]] && usage

while [[ $# -gt 0 ]]; do
    case "$1" in
        --list)    list_only=1; shift ;;
        --restart) restart=1; shift ;;
        --dry-run) dry_run=1; shift ;;
        -h|--help) usage ;;
        --)        shift; group_id="${1:-}"; [[ -n "$group_id" ]] && shift ;;
        -[0-9]*)   group_id="$1"; shift ;;
        -*)        echo "Unknown option: $1" >&2; exit 1 ;;
        *)         group_id="$1"; shift ;;
    esac
done

if [[ ! -r "$SESSIONS_FILE" ]]; then
    echo "ERROR: cannot read $SESSIONS_FILE" >&2
    echo "  Set CM_MAIN_SESSIONS_FILE if your workspace is non-default." >&2
    exit 1
fi

# --- --list mode: print every telegram:group session entry ------------------
if [[ "$list_only" -eq 1 ]]; then
    echo "Telegram group sessions currently registered:"
    echo "  file: $SESSIONS_FILE"
    echo
    /usr/bin/node -e '
        const fs = require("fs");
        const j = JSON.parse(fs.readFileSync(process.argv[1], "utf8"));
        const rows = Object.entries(j)
            .filter(([k]) => k.includes("telegram:group"))
            .map(([k, v]) => ({
                key: k,
                groupId: k.replace("agent:main:telegram:group:", ""),
                authProfile: v.authProfileOverride || "-",
                updatedAt: v.updatedAt ? new Date(v.updatedAt).toISOString() : "-",
                sessionId: v.sessionId || "-",
            }))
            .sort((a, b) => a.groupId.localeCompare(b.groupId));
        if (rows.length === 0) { console.log("  (none)"); process.exit(0); }
        const w = { g: Math.max(10, ...rows.map(r => r.groupId.length)) };
        console.log("  " + "groupId".padEnd(w.g) + "  authProfileOverride             updatedAt");
        console.log("  " + "-".repeat(w.g) + "  ------------------------------  --------------------");
        for (const r of rows) {
            const pinned = r.authProfile !== "-";
            const marker = pinned ? " <- PINNED (candidate for release)" : "";
            console.log("  " + r.groupId.padEnd(w.g) + "  " + r.authProfile.padEnd(30) + "  " + r.updatedAt + marker);
        }
    ' "$SESSIONS_FILE"
    exit 0
fi

if [[ -z "$group_id" ]]; then
    echo "ERROR: <groupId> is required (or use --list)." >&2
    exit 1
fi

session_key="agent:main:telegram:group:${group_id}"

# --- inspect the current entry ----------------------------------------------
echo "Target"
echo "  file:        $SESSIONS_FILE"
echo "  session key: $session_key"
echo

entry_json="$(/usr/bin/node -e '
    const fs = require("fs");
    const [file, key] = process.argv.slice(1);
    const j = JSON.parse(fs.readFileSync(file, "utf8"));
    process.stdout.write(j[key] ? JSON.stringify(j[key]) : "");
' "$SESSIONS_FILE" "$session_key" 2>/dev/null || true)"

if [[ -z "$entry_json" ]]; then
    echo "Nothing to do: no entry for this group in sessions.json."
    echo "  (Telegram messages to this group will already bind via bindings[].)"
    exit 2
fi

# --- show what we'd remove --------------------------------------------------
echo "Current entry (will be removed):"
/usr/bin/node -e '
    const j = JSON.parse(process.argv[1]);
    const interesting = ["sessionId","authProfileOverride","authProfileOverrideSource","updatedAt","chatType"];
    for (const k of interesting) {
        if (k in j) {
            const v = k === "updatedAt" ? new Date(j[k]).toISOString() : j[k];
            console.log("  " + k.padEnd(28) + ": " + v);
        }
    }
' "$entry_json"
echo

if [[ "$dry_run" -eq 1 ]]; then
    echo "DRY RUN — no changes written."
    echo "  (Re-run without --dry-run to actually release this session.)"
    exit 0
fi

# --- backup + remove (atomic) -----------------------------------------------
ts="$(date -u +%Y%m%dT%H%M%SZ)"
backup="${SESSIONS_FILE}.backup-${ts}"
cp -a "$SESSIONS_FILE" "$backup"
echo "Backup: $backup"

tmp="${SESSIONS_FILE}.tmp-${ts}-$$"
/usr/bin/node -e '
    const fs = require("fs");
    const [src, dst, key] = process.argv.slice(1);
    const j = JSON.parse(fs.readFileSync(src, "utf8"));
    if (!(key in j)) { console.error("entry disappeared between check and write"); process.exit(1); }
    delete j[key];
    fs.writeFileSync(dst, JSON.stringify(j, null, 2) + "\n", { mode: 0o600 });
' "$SESSIONS_FILE" "$tmp" "$session_key"

mv -f "$tmp" "$SESSIONS_FILE"
echo "Removed: $session_key"
echo

# --- optional: restart gateway so it drops in-memory session cache ----------
if [[ "$restart" -eq 1 ]]; then
    if command -v systemctl >/dev/null 2>&1; then
        echo "Restarting $GATEWAY_UNIT ..."
        if systemctl --user restart "$GATEWAY_UNIT"; then
            sleep 1
            state="$(systemctl --user is-active "$GATEWAY_UNIT" 2>&1 || true)"
            echo "  -> $GATEWAY_UNIT is $state"
        else
            echo "  WARN: systemctl restart failed — restart the gateway manually." >&2
        fi
    else
        echo "WARN: systemctl not available; restart $GATEWAY_UNIT manually." >&2
    fi
    echo
fi

echo "Done. Next Telegram message to group $group_id will create a fresh"
echo "session under agents/tars-<slug>/sessions/ and use the CM-bound model."
echo
echo "To restore (if needed):"
echo "  mv '$backup' '$SESSIONS_FILE'"
