#!/usr/bin/env bash
# Kurzkommando für den Laptop (ein Wort, kein langer Pfad).
# Beispiel:  ./scripts/cm-dev restart
# Oder einmal:  ln -sf "$(pwd)/scripts/cm-dev" ~/.local/bin/cm-dev
# Dann von überall:  cm-dev restart

set -euo pipefail
ROOT="$(cd "$(dirname "$0")/.." && pwd)"
cmd="${1:-status}"

case "$cmd" in
start)
    exec "${ROOT}/scripts/start-channel-manager-dev.sh"
    ;;
stop)
    exec "${ROOT}/scripts/stop-channel-manager-dev.sh"
    ;;
restart)
    "${ROOT}/scripts/stop-channel-manager-dev.sh" || true
    sleep 1
    exec "${ROOT}/scripts/start-channel-manager-dev.sh"
    ;;
status)
    echo "=== Ports 3000 / 5173 ==="
    ss -ltnp 2>/dev/null | grep -E ':(3000|5173)\b' || echo "(nichts)"
    echo "=== openclaw-gateway ==="
    systemctl --user is-active openclaw-gateway.service 2>/dev/null || echo "(systemctl nicht verfügbar)"
    ;;
*)
    echo "Nutzen: $0 start | stop | restart | status"
    exit 1
    ;;
esac
