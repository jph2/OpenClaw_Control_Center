# Node.js Server Port (must match Vite proxy in frontend/vite.config.js)
PORT=3000

# Base Workspace Directory for Workbench File Operations 
# CRITICAL: Do not append trailing slashes. Absolute paths only.
WORKSPACE_ROOT=/home/claw-agentbox/.openclaw/workspace

# Optional: comma-separated absolute dirs the Workbench may read/write (e.g. bundled OpenClaw skills).
# If unset, ~/.npm-global/lib/node_modules/openclaw/skills is auto-added when it exists.
# WORKBENCH_EXTRA_ROOTS=/home/you/.npm-global/lib/node_modules/openclaw/skills
# Set to 1 to disable that auto-include:
# WORKBENCH_DISABLE_BUNDLED_SKILLS_ROOT=1
#
# User home (~/) is allowed by default for tree/file (Workbench “Home” quick path). Disable with:
# WORKBENCH_DISABLE_HOME_ROOT=1
#
# Allow listing the whole filesystem from / (use with care):
# WORKBENCH_ALLOW_FS_ROOT=1

# Security: Enable/Disable detailed error logging (development vs production)
NODE_ENV=development

# After “Apply to OpenClaw”, restart user openclaw-gateway so it reloads openclaw.json.
# Set to 1 only if you manage the service elsewhere or this host has no systemd --user.
# CHANNEL_MANAGER_SKIP_GATEWAY_RESTART=1

# OpenClaw Gateway — warm path for Channel Manager chat sends (`openclaw agent` RPC)
# Channel Manager also reads gateway.auth.token + gateway.port from ~/.openclaw/openclaw.json
# (or OPENCLAW_CONFIG_PATH) when these vars are unset, so the CLI uses the running gateway
# instead of embedded mode (~20s cold start). Override here if the backend user cannot read that file.
OPENCLAW_GATEWAY_URL=http://127.0.0.1:18789
# OPENCLAW_GATEWAY_TOKEN=set_to_same_value_as_gateway_auth_token

# Chat send transport (Channel Manager → OpenClaw):
# - Plain text defaults to CLI (`openclaw agent`) when this is unset.
# - Image/media sends always use gateway `chat.send` with attachments; if unset, they behave like `auto`
#   (try gateway using token/URL above or from openclaw.json). Gateway must be running and reachable.
# OPENCLAW_CM_SEND_TRANSPORT=auto
# OPENCLAW_CM_SEND_TRANSPORT=gateway
#
# Gateway `chat.send` waits for final delivery when true (default). Set to 0 to shorten HTTP response time
# if the reverse proxy or browser drops long requests (media uploads); OpenClaw may still be processing.
# OPENCLAW_CM_GATEWAY_EXPECT_FINAL=0

# Open Brain sync: only "stub" is implemented (local audit file under Prototyp/channel_CHAT-manager/).
# Future providers may call OB1; unset defaults to stub.
# OPEN_BRAIN_SYNC_PROVIDER=stub
