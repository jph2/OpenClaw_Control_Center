# Copy this file to .env and adjust values as needed
# DO NOT commit .env to git (contains local configuration)

# Optional: direct backend URL (browser calls this host for /api).
# Leave unset for normal dev: same-origin /api → Vite proxy → backend (required when the browser
# is on another machine and only dev-server port 5173 is forwarded, e.g. SSH to the laptop).
# Set http://localhost:3000 only if the browser can reach the backend on that host (or forward :3000 too).
# VITE_API_BASE_URL=http://localhost:3000
